# 🪸 CORAL-CORE Environment Configuration
# Biomineralization Dynamics & Reef Hydro-Acoustic Buffering Framework
# Version: 1.0.0 | DOI: 10.5281/zenodo.18913829

# ============================================
# STATION CONFIGURATION
# ============================================

# Station Identification
STATION_ID="RAS_MOHAMMED_01"              # Unique station identifier
STATION_NAME="Ras Mohammed National Park"  # Human-readable name
STATION_LAT=27.75                          # Latitude (decimal degrees)
STATION_LON=34.23                          # Longitude (decimal degrees)
STATION_DEPTH=15                            # Average depth (m)
REEF_PROVINCE="Indo-Pacific"                # Reef province
DEPLOYMENT_DATE="2026-03-08"                # Deployment date (YYYY-MM-DD)

# Timezone
TIMEZONE="UTC+2"                            # Local timezone
DATE_FORMAT="%Y-%m-%d %H:%M:%S"              # Timestamp format

# ============================================
# SENSOR CONFIGURATION
# ============================================

# SAMI-alk pH/Alkalinity Sensor
SAMI_ENABLED=true
SAMI_PORT="/dev/ttyUSB0"                     # Serial port
SAMI_BAUDRATE=9600                            # Communication speed
SAMI_INTERVAL=900                              # Sampling interval (seconds)
SAMI_CALIBRATION_FILE="config/sami_calib_2026.json"

# AMAR G4 Acoustic Recorder
AMAR_ENABLED=true
AMAR_MOUNT="/mnt/amar"                         # Mount point for storage
AMAR_SAMPLE_RATE=96000                          # Sampling rate (Hz)
AMAR_GAIN=0                                      # Gain setting (dB)
AMAR_HYDROPHONE_DEPTH=10                         # Hydrophone depth (m)

# Diving-PAM Fluorometer
PAM_ENABLED=true
PAM_PORT="/dev/ttyUSB1"                          # Serial port
PAM_BAUDRATE=19200                                # Communication speed
PAM_MEASUREMENT_INTERVAL=3600                      # Measurement interval (seconds)
PAM_DARK_ADAPT_TIME=600                             # Dark adaptation time (seconds)
PAM_COLONIES_FILE="config/pam_colonies.csv"          # Monitored colonies list

# ADCP Workhorse Current Profiler
ADCP_ENABLED=true
ADCP_IP="192.168.1.100"                            # IP address
ADCP_PORT=5000                                       # Port number
ADCP_BURST_INTERVAL=900                               # Burst sampling interval (seconds)
ADCP_BURST_DURATION=300                                # Burst duration (seconds)
ADCP_CELL_SIZE=0.5                                      # Bin size (m)
ADCP_NUM_CELLS=40                                        # Number of bins

# SBE37 MicroCAT CTD
SBE37_ENABLED=true
SBE37_PORT="/dev/ttyUSB2"                             # Serial port
SBE37_BAUDRATE=9600                                     # Communication speed
SBE37_INTERVAL=60                                         # Sampling interval (seconds)
SBE37_CALIBRATION_DATE="2026-01-15"                       # Last calibration date

# GoPro Stereo System
GOPRO_ENABLED=true
GOPRO_WIFI_SSID="GoPro-123456"                           # WiFi SSID
GOPRO_WIFI_PASSWORD="gopro1234"                           # WiFi password
GOPRO_PHOTO_INTERVAL=0.5                                    # Photo interval (seconds)
GOPRO_SURVEY_ALTITUDE=1.0                                    # Survey altitude (m)
GOPRO_OVERLAP=0.8                                             # Image overlap fraction

# ============================================
# DATA STORAGE
# ============================================

# Local Storage
DATA_DIR="/data/coralcore"                                 # Main data directory
RAW_DATA_DIR="${DATA_DIR}/raw"                               # Raw sensor data
PROCESSED_DATA_DIR="${DATA_DIR}/processed"                   # Processed data
BACKUP_DIR="${DATA_DIR}/backup"                               # Backup directory
ARCHIVE_DIR="${DATA_DIR}/archive"                             # Long-term archive

# Database Configuration
DB_TYPE="postgresql"                                         # Database type
DB_HOST="localhost"                                           # Database host
DB_PORT=5432                                                   # Database port
DB_NAME="coralcore"                                            # Database name
DB_USER="coraluser"                                             # Database user
DB_PASSWORD="changeme"                                           # Database password
DB_POOL_SIZE=10                                                   # Connection pool size
DB_SSL_MODE="require"                                              # SSL mode (disable/require/verify)

# TimescaleDB (for time-series optimization)
TIMESCALE_ENABLED=true
TIMESCALE_CHUNK_INTERVAL="7 days"                                 # Chunk interval
TIMESCALE_RETENTION_PERIOD="5 years"                               # Data retention
TIMESCALE_COMPRESSION=true                                           # Enable compression
TIMESCALE_COMPRESSION_AFTER="30 days"                                 # Compress after

# Object Storage (S3-compatible)
S3_ENABLED=false
S3_ENDPOINT="https://s3.amazonaws.com"                             # S3 endpoint
S3_BUCKET="coralcore-raw-data"                                       # Bucket name
S3_ACCESS_KEY="your_access_key_here"                                 # Access key
S3_SECRET_KEY="your_secret_key_here"                                 # Secret key
S3_REGION="us-east-1"                                                 # Region
S3_USE_SSL=true                                                        # Use SSL

# ============================================
# DATA PROCESSING
# ============================================

# Processing Pipeline
PROCESSING_INTERVAL=3600                                          # Processing interval (seconds)
PROCESSING_BATCH_SIZE=1000                                          # Batch size
PROCESSING_WORKERS=4                                                 # Number of workers
PROCESSING_QUEUE_SIZE=10000                                           # Queue size

# Quality Control
QC_ENABLED=true
QC_MIN_TEMPERATURE=15                                                # Min valid temperature (°C)
QC_MAX_TEMPERATURE=40                                                  # Max valid temperature (°C)
QC_MIN_PH=7.5                                                          # Min valid pH
QC_MAX_PH=8.5                                                          # Max valid pH
QC_MIN_SALINITY=30                                                     # Min valid salinity (PSU)
QC_MAX_SALINITY=42                                                      # Max valid salinity (PSU)
QC_OUTLIER_THRESHOLD=3.0                                                # Std dev for outlier detection

# RHI Calculation
RHI_WEIGHTS_FILE="config/rhi_weights.json"                           # Custom weights (optional)
RHI_UPDATE_INTERVAL=3600                                                # RHI calculation interval
RHI_HISTORY_DAYS=30                                                      # Days for trend analysis

# ============================================
# NETWORK & SYNC
# ============================================

# Cloud Sync
SYNC_ENABLED=true
SYNC_INTERVAL=3600                                                   # Sync interval (seconds)
SYNC_MAX_BATCH_SIZE=1000                                               # Max records per batch
SYNC_COMPRESSION="gzip"                                                 # Compression (none/gzip/zlib)
SYNC_ENDPOINT="https://api.coralcore.netlify.app/sync"                  # Sync endpoint
SYNC_API_KEY="your_api_key_here"                                         # API key for authentication

# MQTT (Real-time)
MQTT_ENABLED=true
MQTT_BROKER="mqtt.coralcore.netlify.app"                               # MQTT broker
MQTT_PORT=8883                                                            # MQTT port (8883 for TLS)
MQTT_USE_TLS=true                                                          # Use TLS encryption
MQTT_USERNAME="coralcore"                                                  # Username
MQTT_PASSWORD="changeme"                                                    # Password
MQTT_TOPIC_PREFIX="coralcore/${STATION_ID}"                                 # Topic prefix

# ============================================
# ALERTING
# ============================================

# Alert Configuration
ALERTS_ENABLED=true
ALERT_CHECK_INTERVAL=300                                                # Check interval (seconds)

# Alert Thresholds
RHI_CRITICAL_THRESHOLD=0.5                                              # Critical RHI threshold
RHI_WARNING_THRESHOLD=0.7                                                # Warning RHI threshold
TEMP_BLEACHING_THRESHOLD=1.5                                              # °C above MMM
PHI_PS_STRESS_THRESHOLD=0.4                                                # Quantum yield stress
G_CA_STRESS_THRESHOLD=0.5                                                  # Calcification stress

# Notification Channels
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_SERVER="smtp.gmail.com"                                       # SMTP server
ALERT_EMAIL_PORT=587                                                        # SMTP port
ALERT_EMAIL_USER="alerts@coralcore.org"                                     # Email user
ALERT_EMAIL_PASSWORD="changeme"                                              # Email password
ALERT_EMAIL_RECIPIENTS="monitor@coralcore.org,manager@reef.org"             # Recipients

ALERT_SMS_ENABLED=false
ALERT_SMS_PROVIDER="twilio"                                                # SMS provider
ALERT_SMS_ACCOUNT_SID="your_account_sid"                                    # Account SID
ALERT_SMS_AUTH_TOKEN="your_auth_token"                                      # Auth token
ALERT_SMS_FROM="+1234567890"                                                 # From number
ALERT_SMS_TO="+1234567890"                                                   # To number

ALERT_SLACK_ENABLED=false
ALERT_SLACK_WEBHOOK="https://hooks.slack.com/services/xxx/yyy/zzz"         # Slack webhook
ALERT_SLACK_CHANNEL="#coralcore-alerts"                                      # Slack channel

# ============================================
# WEB DASHBOARD
# ============================================

# Flask Configuration
FLASK_ENV="production"                                                    # Environment
FLASK_APP="web/app.py"                                                     # App entry point
FLASK_DEBUG=false                                                            # Debug mode
FLASK_PORT=5000                                                              # Port
FLASK_HOST="0.0.0.0"                                                         # Host

# Dashboard Settings
DASHBOARD_TITLE="CORAL-CORE Reef Health Monitor"                          # Dashboard title
DASHBOARD_REFRESH=60                                                         # Auto-refresh (seconds)
DASHBOARD_THEME="dark"                                                        # Theme (light/dark)
DASHBOARD_LANGUAGE="en"                                                       # Language

# Authentication
AUTH_ENABLED=true
AUTH_JWT_SECRET="your_jwt_secret_here_change_me"                           # JWT secret
AUTH_JWT_EXPIRY=86400                                                         # Token expiry (seconds)
AUTH_ALLOWED_USERS="admin:admin123,viewer:viewer123"                         # User:password pairs

# SSL/TLS
SSL_ENABLED=false
SSL_CERT_FILE="config/ssl/cert.pem"                                         # SSL certificate
SSL_KEY_FILE="config/ssl/key.pem"                                           # SSL key

# ============================================
# MACHINE LEARNING
# ============================================

# Bleaching Prediction Model
ML_BLEACHING_MODEL="models/bleaching_lstm_v1.h5"                          # Model path
ML_BLEACHING_THRESHOLD=0.5                                                   # Prediction threshold
ML_BLEACHING_HISTORY_DAYS=60                                                  # Days of history

# Acoustic Classification
ML_ACOUSTIC_MODEL="models/acoustic_cnn_v1.h5"                              # Model path
ML_ACOUSTIC_SPECIES=32                                                        # Number of species
ML_ACOUSTIC_CONFIDENCE=0.7                                                    # Min confidence

# RHI Forecasting
ML_FORECAST_HORIZON=30                                                       # Forecast days
ML_FORECAST_MODEL="models/rhi_prophet.pkl"                                   # Model path
ML_UNCERTAINTY_INTERVAL=0.95                                                  # Confidence interval

# ============================================
# GPU ACCELERATION
# ============================================

CUDA_ENABLED=false                                                          # Enable GPU
CUDA_DEVICE=0                                                                # GPU device ID
CUDA_MEMORY_LIMIT=0.8                                                         # Memory limit fraction
TENSORRT_ENABLED=false                                                        # Use TensorRT
TENSORRT_PRECISION="fp16"                                                      # Precision (fp32/fp16/int8)

# ============================================
# LOGGING
# ============================================

LOG_LEVEL="INFO"                                                            # Log level
LOG_FILE="logs/coralcore.log"                                               # Log file
LOG_MAX_SIZE="100MB"                                                          # Max log size
LOG_BACKUP_COUNT=10                                                            # Number of backups
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"             # Log format
LOG_SENSOR_DATA=false                                                          # Log sensor readings

# ============================================
# MONITORING
# ============================================

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8000                                                         # Metrics port
PROMETHEUS_PATH="/metrics"                                                     # Metrics endpoint

# Health Checks
HEALTH_CHECK_INTERVAL=60                                                      # Check interval (seconds)
HEALTH_CHECK_ENDPOINT="/health"                                                # Health endpoint

# ============================================
# ADVANCED SETTINGS
# ============================================

# Performance Tuning
MAX_WORKERS=8                                                                # Max worker threads
QUEUE_SIZE=10000                                                              # Queue size
CACHE_SIZE_MB=1024                                                             # Cache size
COMPRESSION_LEVEL=6                                                             # Compression level (1-9)

# Error Handling
MAX_RETRIES=3                                                                 # Max retry attempts
RETRY_DELAY=60                                                                  # Delay between retries
CIRCUIT_BREAKER_THRESHOLD=5                                                     # Errors before break
CIRCUIT_BREAKER_TIMEOUT=300                                                      # Break duration

# Experimental Features
EXPERIMENTAL_ENABLED=false                                                     # Enable experimental
EXPERIMENTAL_E_DNA=true                                                         # eDNA integration
EXPERIMENTAL_SATELLITE=true                                                      # Satellite data
EXPERIMENTAL_3D_PRINTING=false                                                    # 3D printing tools

# ============================================
# CONTACT INFORMATION
# ============================================

# Project Lead
CONTACT_NAME="Samir Baladi"
CONTACT_EMAIL="gitdeeper@gmail.com"
CONTACT_ORCID="0009-0003-8903-0029"
CONTACT_PHONE="+1 (614) 264-2074"

# Support
SUPPORT_EMAIL="support@coralcore.org"
SUPPORT_HOURS="24/7"

# ============================================
# CITATION
# ============================================

# How to cite this project
CITATION_DOI="10.5281/zenodo.18913829"
CITATION_URL="https://coralcore.netlify.app/citation"

# ============================================
# END OF CONFIGURATION
# ============================================

# Important Notes:
# 1. Change all default passwords before deployment
# 2. Verify sensor ports before starting services
# 3. Test connectivity to cloud endpoints
# 4. Configure firewall rules appropriately
# 5. Set up regular backups
# 6. Monitor disk space usage
# 7. Update calibration dates regularly
